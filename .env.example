# ============================================================
# Configuración del Sistema de Gestión de Taller de Impresoras
# Guía: Copia este archivo a .env y completa los valores
# IMPORTANTE: NUNCA hagas commit del archivo .env real
# ============================================================

# Clave secreta de Flask - GENERAR UNA NUEVA Y FUERTE
# Puedes generar una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=tu-clave-secreta-muy-segura-aqui

# Modo debug (SIEMPRE False en producción)
FLASK_ENV=production
FLASK_DEBUG=False

# Configuración de base de datos (opcional)
DATABASE_URL=sqlite:///taller.db

# Configuración de email (opcional, para futuro uso)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Modo mantenimiento
MAINTENANCE_MODE=False
